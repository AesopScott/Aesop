                                                                  "statusMessage":  "Auto-approving permission...",
                                                                  "command":  "input=$(cat); tool=$(echo \"$input\" | jq -r \u0027.tool_name // empty\u0027); settings=\"C:/Users/scott/Code/Aesop/.claude/settings.json\"; if [ -n \"$tool\" ]; then in_list=$(jq -r --arg t \"$tool\" \u0027[.permissions.allow[] | select(startswith($t))] | length\u0027 \"$settings\" 2\u003e/dev/null || echo 0); if [ \"$in_list\" = \"0\" ]; then tmp=$(mktemp); jq --arg t \"$tool\" \u0027.permissions.allow += [$t]\u0027 \"$settings\" \u003e \"$tmp\" \u0026\u0026 mv \"$tmp\" \"$settings\"; fi; fi; echo \u0027{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"permissionDecision\":\"allow\"}}\u0027"
                                                              }
                                                          ]
                                            }
                                        ],
