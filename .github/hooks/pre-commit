#!/bin/sh
# ──────────────────────────────────────────────────────────
# Pre-commit hook: auto-bump HTML version numbers
# Format on line 2: <!-- v{MAJOR}.{MINOR}.{PATCH} | YYYY-MM-DD -->
# Bumps PATCH and updates date on every commit that touches an HTML file.
# If no version line exists yet, inserts v1.0.0 with today's date.
# ──────────────────────────────────────────────────────────

TODAY=$(date +%Y-%m-%d)

# Get staged .html files (added, modified, copied, renamed)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -i '\.html$')

if [ -z "$STAGED" ]; then
  exit 0
fi

for FILE in $STAGED; do
  # Skip if file doesn't exist (deleted)
  [ -f "$FILE" ] || continue

  LINE2=$(sed -n '2p' "$FILE")

  if echo "$LINE2" | grep -qE '^<!-- v[0-9]+\.[0-9]+\.[0-9]+ \| [0-9]{4}-[0-9]{2}-[0-9]{2} -->$'; then
    # Extract current version parts
    MAJOR=$(echo "$LINE2" | sed -E 's/^<!-- v([0-9]+)\.([0-9]+)\.([0-9]+) \|.*/\1/')
    MINOR=$(echo "$LINE2" | sed -E 's/^<!-- v([0-9]+)\.([0-9]+)\.([0-9]+) \|.*/\2/')
    PATCH=$(echo "$LINE2" | sed -E 's/^<!-- v([0-9]+)\.([0-9]+)\.([0-9]+) \|.*/\3/')

    # Bump patch
    PATCH=$((PATCH + 1))

    NEW_LINE="<!-- v${MAJOR}.${MINOR}.${PATCH} | ${TODAY} -->"
    sed -i "2s/.*/${NEW_LINE}/" "$FILE"
  else
    # No version line on line 2 — insert one after line 1
    sed -i "1a\\<!-- v1.0.0 | ${TODAY} -->" "$FILE"
  fi

  git add "$FILE"
done

exit 0
