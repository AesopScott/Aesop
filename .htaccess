Options -Indexes
DirectoryIndex index.html

# Correct MIME types
AddType text/css .css
AddType application/javascript .js

# Force HTTPS
RewriteEngine On

# Allow direct file access (assets, css, js, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# www to non-www
RewriteCond %{HTTP_HOST} ^www\.aesopacademy\.org [NC]
RewriteRule ^(.*)$ https://aesopacademy.org/$1 [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── STANDALONE MODULE VIEWER ─────────────────────────────
# Clean URLs: /courses/{folder}/m{N} → module-view.php
# Example:    /courses/ai-governance/m1 → full standalone page
RewriteRule ^courses/([a-zA-Z0-9_-]+)/m([0-9]+)/?$ /ai-academy/modules/module-view.php?course=$1&module=$2 [L,QSA]

# Custom 404
ErrorDocument 404 /index.html

# ─── CSS/JS CACHE CONTROL ─────────────────────────────────
# Forces browsers to revalidate CSS and JS on every visit.
# ETag lets the server say "nothing changed, use your copy"
# without re-sending the whole file — fast AND always fresh.
 
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header unset Expires
  </FilesMatch>
</IfModule>
 
<IfModule mod_expires.c>
  <FilesMatch "\.(css|js)$">
    ExpiresActive Off
  </FilesMatch>
</IfModule>
 
