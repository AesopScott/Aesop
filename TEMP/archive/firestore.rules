rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── PlayAGame forum threads ──
    match /forum_threads/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0;
      allow update: if request.auth != null
        && (
          resource.data.authorId == request.auth.uid
          || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['votes', 'voters']))
        );
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']);
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0;
        allow update: if request.auth != null
          && (
            resource.data.authorId == request.auth.uid
            || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']
            || (request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['likes', 'likers']))
          );
        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid
              || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']);
      }
    }

    // ── AESOP Academy forum threads ──
    match /academy_forum_threads/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0;
      allow update: if request.auth != null
        && (
          resource.data.authorId == request.auth.uid
          || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['votes', 'voters']))
        );
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']);
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0;
        allow update: if request.auth != null
          && (
            resource.data.authorId == request.auth.uid
            || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']
            || (request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['likes', 'likers']))
          );
        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid
              || request.auth.uid in ['sSSbSFRlG7cc18MpywDACkRQg5H3']);
      }
    }

  }
}
