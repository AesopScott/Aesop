// =============================================================================
// firestore.rules  —  AESOP AI Academy + THE LADDER unified data layer
// =============================================================================
// DEPLOYED 2026-07-02 with Phase 2 auth modal + Phase 3 save-progress prompt.
// Previously a draft (authored by the data-layer worktree alongside ADR
// docs/adr/0001-ladder-database-of-record.md and docs/ladder-data-model.md).
//
// IDENTITY MODEL:
//   Two-tier access matching three codebase patterns:
//     1. Anonymous learners (AESOP-XXXX, no Firebase auth) — own docs that
//        have no `accountUid` field. Access is path-based (learnerId).
//     2. Signed-in learners (email/password or Google OAuth) — own docs where
//        `accountUid == request.auth.uid`. Auth-modal.js links the Firebase
//        account to the anonymous learner doc on sign-up/sign-in.
//     3. Admins — custom claim `admin == true` (set out of band in Firebase).
//
//   Tier 2 is upgradeable from Tier 1: when a learner creates an account, the
//   client merges `{accountUid, accountEmail}` into their existing learner doc.
//   After binding, the doc is owned by that account and anonymous path-based
//   access is locked out.
//
//   Certs/evidence still allow anon reads to match the current prod behavior.
// =============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Owner check for a learner-scoped doc. A signed-in user owns the doc when
    // their uid matches the doc's accountUid. Anonymous learners (no auth) are
    // permitted on docs without an accountUid (legacy anon-learnerId pattern).
    // Once accountUid is set, the anonymous path is locked out and only the
    // bound account (or admin) may access the doc.
    function ownsLearner(learnerId, resourceData) {
      return isAdmin()
        || (isSignedIn() && resourceData != null && resourceData.accountUid == request.auth.uid)
        || (resourceData == null)               // creating a brand-new anon record
        || (resourceData != null && (resourceData.accountUid == null || resourceData.accountUid == '')); // legacy anon record
    }

    // ---- learners/{learnerId} --------------------------------------------
    // Unified learner record across all three pathways.
    // Two access tiers: signed-in users own the doc matching their accountUid;
    // anonymous learners can read/write docs that have no accountUid bound yet.
    // Once accountUid is set, only that user or admin may mutate the doc.
    match /learners/{learnerId} {
      allow create: if ownsLearner(learnerId, null);  // new anon or signed-in owner
      allow read:   if isAdmin()
                    || (isSignedIn() && resource.data.accountUid == request.auth.uid)
                    || (!isSignedIn() && (resource.data.accountUid == null || resource.data.accountUid == ''));
      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.accountUid == request.auth.uid)
                    || (resource.data.accountUid == null || resource.data.accountUid == '');
      allow delete: if isAdmin();
    }

    // ---- completions/{completionId} --------------------------------------
    // Pathway-agnostic completion log. Owner-create, owner+admin read.
    match /completions/{completionId} {
      allow read:   if isAdmin()
                    || (isSignedIn() && resource.data.learnerId != null);
      allow create: if request.resource.data.learnerId is string;
      allow update, delete: if isAdmin();
    }

    // ---- certifications/{certificationId} --------------------------------
    // Awarded credentials. Read by owner+admin; writes controlled.
    // Created by the client at award time today; an issuer/Cloud-Function path
    // should eventually own creation. Once written, only admin may mutate.
    match /certifications/{certificationId} {
      allow read:   if isAdmin()
                    || (isSignedIn() && resource.data.accountUid == request.auth.uid)
                    || (resource.data.accountUid == null || resource.data.accountUid == '');
      allow create: if request.resource.data.learnerId is string
                    && request.resource.data.result in ['pass', 'non_pass'];
      allow update, delete: if isAdmin();  // credentials are immutable post-award except by admin
    }

    // ---- evidencePackets/{evidencePacketId} ------------------------------
    // Per-attempt evidence (doc-16 field list). Read by owner+admin.
    // Immutable after create (challenge outcomes live in the challengePackets
    // subcollection); only admin may amend.
    match /evidencePackets/{evidencePacketId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.learnerId != null);
      allow create: if request.resource.data.learnerId is string;
      allow update, delete: if isAdmin();

      match /challengePackets/{challengePacketId} {
        allow read:   if isAdmin() || isSignedIn();
        allow create: if isSignedIn();   // learner files a challenge
        allow update, delete: if isAdmin(); // resolution is admin/reviewer-controlled
      }
    }

    // ---- certificationValidations/{validationId} -------------------------
    // Second-model validation records. Read by owner+admin; create controlled.
    match /certificationValidations/{validationId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.learnerId != null);
      allow create: if request.resource.data.learnerId is string
                    && request.resource.data.evidencePacketId is string;
      allow update, delete: if isAdmin();
    }

    // ---- standardsEvidence/{standardsEvidenceId} -------------------------
    // ADVISORY candidate evidence only. New records MUST be created as
    // 'candidate'. Status upgrades (learner_confirmed / reviewer_verified /
    // rejected / stale) are gated: a learner may confirm/reject their OWN
    // candidate; only admin/reviewer may set reviewer_verified.
    match /standardsEvidence/{standardsEvidenceId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.learnerId != null)
                    || (resource.data.learnerId == null || resource.data.learnerId == '');
      // Creation must start as candidate — no engine may write a verified record.
      allow create: if request.resource.data.status == 'candidate'
                    && request.resource.data.linkedStandard != null
                    && request.resource.data.transcriptSpan != null;
      // Learner self-confirmation/rejection of their own candidate.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.status == 'candidate'
                        && request.resource.data.status in ['learner_confirmed', 'rejected', 'stale']);
      allow delete: if isAdmin();
    }

    // ---- resource & mapping catalogs (doc 15) ----------------------------
    // Read-mostly reference data; admin-only writes.
    match /rungs/{rungId}                  { allow read: if true; allow write: if isAdmin(); }
    match /resources/{resourceId}          { allow read: if true; allow write: if isAdmin(); }
    match /videos/{videoId}                { allow read: if true; allow write: if isAdmin(); }
    match /courses/{courseId}              { allow read: if true; allow write: if isAdmin(); }
    match /products/{productId}            { allow read: if true; allow write: if isAdmin(); }
    match /useCases/{useCaseId}            { allow read: if true; allow write: if isAdmin(); }
    match /assignmentLabs/{labId}          { allow read: if true; allow write: if isAdmin(); }
    match /standardsDefinitions/{stdId}    { allow read: if true; allow write: if isAdmin(); }
    match /resourceResearchRuns/{runId}    { allow read: if isAdmin(); allow write: if isAdmin(); }

    // ---- request queues (already in production, docs 18/19) --------------
    // Public-create, admin-read. Anyone may submit a request; only admins read
    // and triage. Status is admin-controlled after create.
    match /productCourseRequests/{requestId} {
      allow create: if request.resource.data.itemId != null;
      allow read, update, delete: if isAdmin();
    }
    match /useCaseTrainingRequests/{requestId} {
      allow create: if request.resource.data.itemId != null;
      allow read, update, delete: if isAdmin();
    }

    // ---- default deny -----------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
